# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
node_modules/
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production
build/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Operating system files
Thumbs.db
ehthumbs.db

# IDEs and editors
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# Node / package managers
.pnpm-store/
package-lock.json
yarn.lock

# Local environment files (do NOT commit local envs)
.env.local
.env.development.local
.env.test.local
.env.production.local

# Build outputs & caches
.cache/
dist/
.build/

# Logs
*.log
logs/
npm-debug.log*
yarn-debug.log*
.pnpm-debug.log*

# Misc
.vscode-test/
.sass-cache/
cache-loader/
