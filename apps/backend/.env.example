# =============================================================================
# Backend env example — Puntualo
#   - Secrets / credenciales: placeholders vacios o "changeme".
#   - Constantes tuneables del proyecto: defaults conocidos (documentan los knobs).
# =============================================================================

# --- Database (secret)
# Supabase Postgres — usar el "Session pooler" (IPv4, puerto 5432); la conexion
# directa db.<ref>.supabase.co es IPv6-only y falla en redes sin IPv6.
# Requiere ?sslmode=require al final. Si el password trae caracteres especiales
# (@ : / ? # %), URL-encodearlos (@ -> %40, : -> %3A, etc.).
# postgresql://postgres.<ref>:<password>@aws-1-<region>.pooler.supabase.com:5432/postgres?sslmode=require
DATABASE_URL=

# --- CORS
# Orígenes del frontend autorizados (separados por coma, sin barra final).
# Dev: http://localhost:3000 · Prod: la URL de Vercel y/o tu dominio.
FRONTEND_ORIGINS=http://localhost:3000

# --- Auth (secrets)
SECRET_KEY=changeme
JWT_SECRET=changeme
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- OAuth Google (secrets)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Pipeline de validacion (tuneables)
UNMSM_USER_AGENT=Puntualo-Research/1.0 (mailto:contacto@puntualo.dev)
UNMSM_RATE_LIMIT_SECONDS=1.0
OPENALEX_API_BASE=https://api.openalex.org
OPENALEX_INSTITUTION_ID=I192513696
OPENALEX_USER_AGENT=Puntualo/1.0 (mailto:contacto@puntualo.dev)
ORCID_API_BASE=https://pub.orcid.org/v3.0
ORCID_AFFILIATION_NAME=Universidad Nacional Mayor de San Marcos

# Tavily (secret + tuneables)
TAVILY_API_KEY=
TAVILY_API_BASE=https://api.tavily.com
TAVILY_BUDGET_HARD_CAP=950
TAVILY_BUDGET_SOFT_WARNING=760

# HTTP / circuito
PIPELINE_TIMEOUT_CONNECT=5.0
PIPELINE_TIMEOUT_READ=10.0
PIPELINE_MAX_RETRIES=3
PIPELINE_BACKOFF_BASE=2.0
CIRCUIT_THRESHOLD=5
CIRCUIT_RESET_SECONDS=300
CACHE_TTL_VALIDATION_SECONDS=86400
CACHE_TTL_ENRICHMENT_SECONDS=604800

# --- Redis + Celery
# REDIS_PASSWORD (secret): protege Redis incluso en red interna. En prod, las URLs
# apuntan al servicio `redis` de Docker e incluyen la password, p.ej.:
#   redis://:${REDIS_PASSWORD}@redis:6379/0
# En dev (Redis local sin password) basta con redis://localhost:6379/N.
REDIS_PASSWORD=changeme
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- Supabase Storage (secrets)
# URL del proyecto y claves. La service_role key tiene permisos plenos: NUNCA exponer al cliente.
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_BUCKET_NAME=Puntualo

# --- Email / SMTP (secrets + tuneables)
# Credenciales del servidor de correo (verificación de cuenta, reset de password).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TLS=true
SMTP_SSL=false

# --- Verificación de email y reset de password (tuneables)
EMAIL_VERIFICATION_TTL_MINUTES=10
EMAIL_VERIFICATION_MAX_ATTEMPTS=5
PASSWORD_RESET_TTL_MINUTES=10
PASSWORD_RESET_MAX_ATTEMPTS=5

# =============================================================================
# Tarea 2.6 — Rating, Comentarios y Crowdsourcing
# =============================================================================
# Nota: los pesos del score (clarity / easiness / helpfulness / punctuality)
# estan hardcoded en app/core/config.py a 0.25 cada uno y NO son customizables
# desde el .env. Si necesitas cambiarlos, edita config.py directamente.

# --- Validacion de comentarios
COMMENT_MIN_LENGTH=20
COMMENT_MAX_LENGTH=2000
COMMENT_REPORT_REASON_MAX_LENGTH=500

# --- Moderacion
MODERATION_HIDE_THRESHOLD=5
LLM_MODERATION_ENABLED=false
MODERATION_VERIFIED_EMAIL_DOMAIN=unmsm.edu.pe

# --- Heuristic Filter (spam detection & obfuscation)
HEURISTIC_SPAM_BLOCK_THRESHOLD=0.7
HEURISTIC_SPAM_FLAG_THRESHOLD=0.4
HEURISTIC_MAX_UPPERCASE_RATIO=0.7
HEURISTIC_OBFUSCATION_CHECK=true

# --- Report/Complaint System
REPORT_RATE_LIMIT_PER_HOUR=10
REPORT_ABUSE_THRESHOLD=5
REPORT_MODERATION_TRIGGER_THRESHOLD=5.0

# --- Hook resumen IA (se activa cuando este lista la Tarea 4.4)
IA_SUMMARY_HOOK_ENABLED=false
IA_SUMMARY_THRESHOLD=10

# --- Cache TTLs (segundos)
CACHE_TTL_PROFESSOR_DETAIL_SECONDS=300
CACHE_TTL_PROFESSOR_COMMENTS_SECONDS=120
CACHE_TTL_COURSES_SEARCH_SECONDS=60

# --- Override de semestre (solo para tests; formato YYYY-1 o YYYY-2)
# SEMESTER_OVERRIDE=2026-1

# =============================================================================
# Tarea 4.4 — Resumen Ejecutivo Asíncrono (NLP / Gemini)
# =============================================================================
# --- Secret
GEMINI_API_KEY=

# --- Tuneables (defaults conocidos)
GEMINI_MODEL=gemini-2.5-flash
# Modelo del chatbot (flash, no lite: lite rompía las reglas del prompt)
CHATBOT_GEMINI_MODEL=gemini-2.5-flash
NLP_SUMMARY_MIN_REVIEWS=5
NLP_SUMMARY_MAX_REVIEWS=100
NLP_SUMMARY_SAMPLE_RECENT=50
NLP_SUMMARY_SAMPLE_RANDOM=50
NLP_SUMMARY_MAX_INPUT_TOKENS=50000
NLP_SUMMARY_BEAT_SECONDS=900
NLP_LLM_MAX_RETRIES=2

# =============================================================================
# Tarea 4.5 — Chatbot RAG (Cohere embeddings + Gemini chat)
# =============================================================================
# Cohere (secret + tuneables)
COHERE_API_KEY=
COHERE_EMBED_MODEL=embed-v4.0
COHERE_EMBED_DIM=1536
# Vertex AI como backend de Gemini para el chatbot (créditos GCP).
# Con true autentica por ADC (GOOGLE_APPLICATION_CREDENTIALS); GEMINI_API_KEY no aplica.
CHATBOT_USE_VERTEXAI=false
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
# Chatbot (tuneables)
CHATBOT_TOP_K=5
CHATBOT_HISTORY_TURNS=10
CHATBOT_MAX_TOOL_ROUNDS=4
CHATBOT_RATE_LIMIT_PER_HOUR=30
CHATBOT_SYSTEM_PROMPT_VERSION=system_v2
EMBEDDINGS_BEAT_SECONDS=3600
